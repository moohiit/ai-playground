MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/ai-playground
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=replace_with_long_random_string
NODE_ENV=development

# Email delivery via Resend (https://resend.com)
# 1. Sign up, create an API key at https://resend.com/api-keys
# 2. Either verify your own domain in the Resend dashboard (recommended) or
#    use the built-in "onboarding@resend.dev" sender for quick testing.
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=AI Playground <noreply@mohitpatel.org>

# Public URL used in verification / password-reset links (include scheme in prod)
APP_URL=http://localhost:3000

# Cloudinary (profile photo uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
