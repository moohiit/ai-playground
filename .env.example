MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/ai-playground
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=replace_with_long_random_string
NODE_ENV=development

# Email (Gmail app password recommended, or any SMTP provider)
# For Gmail: generate at https://myaccount.google.com/apppasswords
EMAIL_USER=you@example.com
EMAIL_PASS=your_smtp_or_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
EMAIL_FROM=AI Playground <you@example.com>

# Optional: override to use a non-Gmail SMTP server
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587

# Public URL used in verification / password-reset links (include scheme in prod)
APP_URL=http://localhost:3000

# Cloudinary (profile photo uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
