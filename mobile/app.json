{
  "expo": {
    "name": "Expense Tracker",
    "slug": "expense-tracker",
    "scheme": "expensetracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#05060a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moohiit.expensetracker"
    },
    "android": {
      "package": "com.moohiit.expensetracker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Expense Tracker to access your photos to attach a receipt.",
          "cameraPermission": "Allow Expense Tracker to use the camera to scan a receipt.",
          "microphonePermission": false
        }
      ],
      "expo-asset",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b4e4d8f3-c1ad-496a-a758-ed2ea95ac8f3"
      }
    }
  }
}
